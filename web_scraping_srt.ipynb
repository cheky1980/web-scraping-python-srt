https://service.ssn.gob.ar/consulta/consulta_entidades.php
pip install requests beautifulsoup4
import requests
from bs4 import BeautifulSoup
import csv
import time



BASE_URL = "https://service.ssn.gob.ar/consulta/consulta_entidades.php"

# IMPORTANTE:
# Este es el nombre del campo que manda el código de entidad.
# Lo más probable es que sea 'entidad' o 'id_entidad'.
# Si no funciona, abrí el código fuente de la página, buscá el <select>
# de "SELECCIONAR UNA COMPAÑIA" y fijate qué dice name="...".
FORM_FIELD_NAME = "entidad"

# Pausa entre pedidos para no bombardear el servidor (en segundos)
PAUSA_SEGUNDOS = 0.5


# 1) OBTENER LISTA DE ASEGURADORAS


session = requests.Session()

print("Descargando página principal...")
resp = session.get(BASE_URL)
resp.raise_for_status()

soup = BeautifulSoup(resp.text, "html.parser")

options = soup.find_all("option")

aseguradoras = []
for opt in options:
    code = (opt.get("value") or "").strip()
    name = opt.get_text(strip=True)
    if code.isdigit():          # solo códigos numéricos
        aseguradoras.append({"codigo": code, "nombre": name})

print(f"Se encontraron {len(aseguradoras)} aseguradoras.")



# 2) FUNCIÓN PARA OBTENER DETALLE DE UNA ASEGURADORA


def obtener_detalle(codigo):
    """
    Devuelve un diccionario con campos como CUIT, Estado, Domicilio, etc.
    El HTML puede cambiar, así que es genérico: lee todas las filas de tablas
    y arma pares campo: valor (ej: 'CUIT': '30-12345678-9').
    """
    # POST (o GET) con el código de entidad
    # En muchos sitios funciona igual usando GET con params, si el POST no anda:
    # detail_resp = session.get(BASE_URL, params={FORM_FIELD_NAME: codigo})
    detail_resp = session.post(BASE_URL, data={FORM_FIELD_NAME: codigo})
    detail_resp.raise_for_status()

    detail_soup = BeautifulSoup(detail_resp.text, "html.parser")

    detalle = {}

    # Buscamos tablas y leemos filas tipo "Campo : Valor"
    for table in detail_soup.find_all("table"):
        for tr in table.find_all("tr"):
            celdas = [td.get_text(strip=True) for td in tr.find_all("td")]
            if len(celdas) >= 2:
                campo = celdas[0].rstrip(":").strip()
                valor = celdas[1].strip()
                if campo and valor:
                    detalle[campo] = valor

    return detalle


# 3) RECORRER TODAS LAS ASEGURADORAS Y GUARDAR DATOS

resultados = []

for idx, aseg in enumerate(aseguradoras, start=1):
    codigo = aseg["codigo"]
    nombre = aseg["nombre"]
    print(f"[{idx}/{len(aseguradoras)}] Consultando detalle de {codigo} - {nombre}...")

    try:
        detalle = obtener_detalle(codigo)
    except Exception as e:
        print(f"   ⚠ Error obteniendo detalle de {codigo}: {e}")
        detalle = {}

    # Tomamos los campos que más nos interesan (si existen)
    fila = {
        "Codigo": codigo,
        "Nombre": nombre,
        "CUIT": detalle.get("CUIT", ""),
        "Estado": detalle.get("Estado", detalle.get("Estado de la entidad", "")),
        "Domicilio": detalle.get("Domicilio", detalle.get("Domicilio legal", "")),
        "Localidad": detalle.get("Localidad", ""),
        "Provincia": detalle.get("Provincia", ""),
        "Telefono": detalle.get("Teléfono", detalle.get("Telefonos", "")),
        "Email": detalle.get("Email", detalle.get("E-mail", "")),
    }

    resultados.append(fila)

    time.sleep(PAUSA_SEGUNDOS)  # para no sobrecargar el servidor



# 4) GUARDAR CSV


nombre_archivo = "aseguradoras_ssn_detalle.csv"

campos = [
    "Codigo",
    "Nombre",
    "CUIT",
    "Estado",
    "Domicilio",
    "Localidad",
    "Provincia",
    "Telefono",
    "Email",
]

with open(nombre_archivo, "w", newline="", encoding="utf-8") as f:
    writer = csv.DictWriter(f, fieldnames=campos)
    writer.writeheader()
    writer.writerows(resultados)

print("\n✔ Proceso terminado.")
print(f"✔ Se guardaron {len(resultados)} filas en '{nombre_archivo}'.")
