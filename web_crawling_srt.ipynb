import urllib
from bs4 import BeautifulSoup
html = urllib.request.urlopen('https://ssnanonymus.se.qlikcloud.com/sense/app/aad2fecd-c702-4cb0-8cd6-a570243b4a4f/sheet/rjkqGs/state/analysis')
soup = BeautifulSoup(html) # tranforma el html a un objeto de beautifulSoup
tags = soup('a') # nos trae todas la etiqueta de tipo a href hiperviculos.
tags

# Seguimos parceando hasta obtener una limpieza de los datos y quedarnos con los que nos interesa qu en este casos son los enlaces.

print ('las cantidad de enlaces son :',len(tags))

print('\n')
for tag in tags:
    print('URL:',tag.get('href'))
    print('\n')

# Limpieza final para quedarno solo con los enlaces, esto tambien nos permite realizar una recusiva copiando y pengando los enlaces como se hizo de un principio para ir limpiando y obtener los datos que queramos, esto es el llamdo CRAWLERS

links_https = []   # Lista vacía

for t in tags:
    link = t.get("href")
    if link and link.startswith("https"):
        print("URL:", link)
        links_https.append(link)   # Agrego el enlace a la lista

print('\n')
print("Cantidad de enlaces https:", len(links_https))
